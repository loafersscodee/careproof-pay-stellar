{
  "name": "careproof-pay",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm --workspace backend run dev\" \"npm --workspace frontend run dev\"",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build": "npm --workspace frontend run build && npm --workspace backend run build",
    "build:contract": "cd contract && make build",
    "db:generate": "npm --workspace backend run db:generate",
    "db:seed": "npm --workspace backend run db:seed"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
