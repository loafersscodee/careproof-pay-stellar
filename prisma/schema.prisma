generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Item {
  id        String   @id @default(cuid())
  title     String
  amount    Float
  status    String   @default("pending")
  wallet    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
